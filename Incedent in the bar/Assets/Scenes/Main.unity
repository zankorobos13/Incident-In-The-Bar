  m_text: "\u041F\u0440\u0438\u0432\u0435\u0442 \u0414\u0436\u043E, \u0443 \u043C\u0435\u043D\u044F
    \u0434\u043B\u044F \u0442\u0435\u0431\u044F \u043E\u0442\u043B\u0438\u0447\u043D\u044B\u0435
    \u043D\u043E\u0432\u043E\u0441\u0442\u0438! \u0412 \u043D\u0430\u0448 \u0431\u0430\u0440
    \u0441\u0435\u0433\u043E\u0434\u043D\u044F \u043F\u0440\u0438\u0439\u0434\u0435\u0442
    \u043A\u0443\u0447\u0430 \u043D\u0430\u0440\u043E\u0434\u0430, \u043A\u0430\u043A\u043E\u0439-\u0442\u043E
    \u0438\u0437\u0432\u0435\u0441\u0442\u043D\u044B\u0439 \u0440\u043E\u043A\u0435\u0440
    \u043F\u0440\u043E\u0432\u043E\u0434\u0438\u043B \u043A\u043E\u043D\u0446\u0435\u0440\u0442
    \u043D\u0435\u043F\u043E\u0434\u0430\u043B\u0451\u043A\u0443 \u0438 \u043E\u043D
    \u0443\u0436\u0435 \u0437\u0430\u043F\u043B\u0430\u0442\u0438\u043B \u0437\u0430
    \u0432\u0441\u0435 \u043D\u0430\u043F\u0438\u0442\u043A\u0438 \u043D\u0430 \u044D\u0442\u043E\u0442
    \u0432\u0435\u0447\u0435\u0440, \u0442\u0430\u043A \u0447\u0442\u043E \u043D\u0430\u043B\u0438\u0432\u0430\u0439
    \u0432\u0441\u0435\u043C \u0431\u0435\u0441\u043F\u043B\u0430\u0442\u043D\u043E.
    \u0417\u043D\u0430\u044E \u044D\u0442\u043E \u0442\u0432\u043E\u0439 \u043F\u0435\u0440\u0432\u044B\u0439
